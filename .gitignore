# Data cache (raw + parquet) - keep the folder, ignore contents
/data/*
!/data/.gitkeep

# Generated outputs - figures under outputs/figures are intentional deliverables
# and ARE committed; only heavy intermediate artifacts are ignored.
/outputs/**/*.pdf
/outputs/**/*.parquet

# Secrets
.env

